import { Response } from 'express';
import { pool } from '../config/db';
import { sendError, sendSuccess } from '../utils/response';
import { AuthRequest } from '../middlewares/authMiddleware';

export const getMe = async (req: AuthRequest, res: Response): Promise<void> => {
  try {
    const result = await pool.query(
      `SELECT id_usuario, nombre, email, edad, genero, fecha_registro, modo_oscuro
       FROM usuario WHERE id_usuario = $1`,
      [req.user!.id_usuario]
    );
    if (result.rows.length === 0) {
      sendError(res, 'Usuario no encontrado', 404);
      return;
    }
    sendSuccess(res, result.rows[0]);
  } catch (err) {
    console.error(err);
    sendError(res, 'Error al obtener perfil', 500);
  }
};

export const updateMe = async (req: AuthRequest, res: Response): Promise<void> => {
  const { nombre, edad, genero, modo_oscuro } = req.body;
  try {
    const result = await pool.query(
      `UPDATE usuario SET
        nombre      = COALESCE($1, nombre),
        edad        = COALESCE($2, edad),
        genero      = COALESCE($3, genero),
        modo_oscuro = COALESCE($4, modo_oscuro)
       WHERE id_usuario = $5
       RETURNING id_usuario, nombre, email, edad, genero, fecha_registro, modo_oscuro`,
      [nombre, edad, genero, modo_oscuro, req.user!.id_usuario]
    );
    sendSuccess(res, result.rows[0]);
  } catch (err) {
    console.error(err);
    sendError(res, 'Error al actualizar perfil', 500);
  }
};